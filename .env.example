BYBIT_API_KEY=your_api_key
BYBIT_API_SECRET=your_api_secret
# Bybit Demo Trading (api-demo.bybit.com) — ключи создаются в режиме Demo Trading на сайте Bybit.
# Для торговли на основном счёте (api.bybit.com) установите BYBIT_DEMO_TRADING=false
BYBIT_DEMO_TRADING=true
# Окно подписи API (мс). Увеличьте при ErrCode 10002 на рассинхроне часов с Bybit.
BYBIT_RECV_WINDOW_MS=20000
# Синхронизация времени подписи с GET /v5/market/time (исправляет ErrCode 10002 при убежавших часах ПК).
BYBIT_ALIGN_TIME_WITH_SERVER=true
MARGIN_MODE=cross
LEVERAGE=10
API_RETRY_ATTEMPTS=4
API_RETRY_BACKOFF_MS=300
LOOP_INTERVAL_SECONDS=15
# Use 0 or negative for infinite loop when running live engine only (not used by --telegram-with-live, which runs forever).
LOOP_ITERATIONS=1


# Risk defaults
BASE_RISK_PCT=1.0
STRONG_RISK_PCT=2.0
MAX_OPEN_POSITIONS=3
MAX_AGGREGATE_RISK_PCT=5.0
DAILY_STOP_PCT=-4.0

# Telegram audit bot
TELEGRAM_BOT_TOKEN=
# Через запятую. Для push-уведомлений о сигналах/ордерах список должен быть непустым.
TELEGRAM_ALLOWED_CHAT_IDS=
# Push в Telegram при сигнале, открытии/закрытии сделки (нужны TOKEN и ALLOWED_CHAT_IDS).
TELEGRAM_TRADE_ALERTS=true

# Частичное закрытие: доля на первом TP (Fib), остаток → BE, затем второй уровень Fib.
PARTIAL_TP_FRACTION=0.5
# Смещение стопа в безубыток от цены входа (basis points, 5 = 0.05%).
BREAKEVEN_OFFSET_BPS=5

# --- Режим процесса (удобно на сервере без CLI-флагов; по умолчанию не задавать) ---
# combined — Telegram + торговый движок (как --serve / --telegram-with-live).
# telegram — только Telegram; trade — только движок по LOOP_ITERATIONS; dry_check — preflight.
# Пусто — как раньше: только движок, число циклов из LOOP_ITERATIONS.
# MATRYOSHKA_RUN_MODE=combined
# Пауза перед перезапуском потока движка после необработанного исключения (секунды, минимум 5).
ENGINE_RESTART_BACKOFF_SECONDS=30
