BYBIT_API_KEY=your_api_key
BYBIT_API_SECRET=your_api_secret
MARGIN_MODE=cross
LEVERAGE=10
API_RETRY_ATTEMPTS=4
API_RETRY_BACKOFF_MS=300
LOOP_INTERVAL_SECONDS=15
# Use 0 or negative for infinite loop when running live engine only (not used by --telegram-with-live, which runs forever).
LOOP_ITERATIONS=1


# Risk defaults
BASE_RISK_PCT=1.0
STRONG_RISK_PCT=2.0
MAX_OPEN_POSITIONS=3
MAX_AGGREGATE_RISK_PCT=5.0
DAILY_STOP_PCT=-4.0

# Telegram audit bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
